# Database Configuration (MongoDB Atlas)
# Local Development:
# DATABASE_URL="mongodb://localhost:27017/ethara-ai"

# Production (MongoDB Atlas):
# 1. Go to: https://mongodb.com/cloud/atlas
# 2. Create account → Create cluster → Get connection string
# 3. Replace [username], [password], [cluster] with your values
DATABASE_URL="mongodb+srv://[username]:[password]@[cluster].mongodb.net/ethara-ai?retryWrites=true&w=majority"

# JWT Secret for token generation (min 32 characters)
# Generate: openssl rand -base64 32
JWT_SECRET="your-super-strong-jwt-secret-key-change-this-in-production"

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration
# Set to your Railway app URL
CORS_ORIGIN="https://ethara-ai-production.railway.app"


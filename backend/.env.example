# Database Configuration (MongoDB)
# 
# Railway Environment (use MONGODB_URI):
# 1. Go to: https://mongodb.com/cloud/atlas
# 2. Create account → Create cluster → Get connection string
# 3. Add connection string to Railway Variables as MONGODB_URI
MONGODB_URI="mongodb+srv://[username]:[password]@[cluster].mongodb.net/ethara-ai?retryWrites=true&w=majority"

# Fallback for local development (DATABASE_URL):
DATABASE_URL="mongodb://localhost:27017/ethara-ai"

# JWT Secret for token generation (min 32 characters)
# Generate: openssl rand -base64 32
JWT_SECRET="your-super-strong-jwt-secret-key-change-this-in-production"

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration
# For local development: http://localhost:5173
# For Railway production: * (or your specific domain)
CORS_ORIGIN="*"
CORS_ORIGIN="https://ethara-ai-production.railway.app"

